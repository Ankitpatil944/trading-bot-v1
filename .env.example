# Copy to .env and fill in. Never commit .env.

KITE_API_KEY=
KITE_API_SECRET=
# After login, either set this or rely on KITE_TOKEN_FILE
KITE_ACCESS_TOKEN=

KITE_EXCHANGE=NSE
KITE_SYMBOLS=INFY,RELIANCE

# Options (index / stock F&O): set OPTIONS_MODE=true, KITE_EXCHANGE=NFO or BFO, exact CE/PE tradingsymbols.
# OPTIONS_MODE=false
# SPOT_SYMBOL=NIFTY 50
# OPTIONS_CE_SYMBOL=
# OPTIONS_PE_SYMBOL=
# OPTIONS_MIN_STOP_LOSS_PCT=12.0
# OPTIONS_DISABLE_ATR_FOR_RISK=true
# OPTIONS_USE_SPOT_ATR_FOR_SIZING=false
# OPTIONS_USE_SPOT_VOLUME_FILTER=true
# OPTIONS_SLIPPAGE_BPS=35
# SLIPPAGE_BPS=2

# Strategy session (IST); matches regular Indian cash/F&O day session by default
# SESSION_START_IST=09:15
# SESSION_END_IST=15:30
# SESSION_TRADE_WEEKENDS=false
# true = simulated orders (recommended until you trust the stack)
PAPER_TRADING=true
# Optional: fixed rupee notional for risk math in paper mode (position size, daily loss % baseline).
# If unset, bot uses Kite margins net equity like live mode.
# PAPER_EQUITY=100000

# WebSocket on by default; set false to use REST LTP polling (coarser candles)
USE_WEBSOCKET=true

CANDLE_INTERVAL_MINUTES=1
HIGHER_TF_MINUTES=5

RISK_PER_TRADE_PCT=1.0
STOP_LOSS_PCT=0.5
STOP_LOSS_USE_ATR=false
STOP_LOSS_ATR_MULT=2.0
# TAKE_PROFIT_PCT=1.0
MAX_TRADES_PER_DAY=10
DAILY_LOSS_LIMIT_PCT=3.0
MAX_OPEN_POSITIONS=0

# Portfolio allocator
MAX_PORTFOLIO_RISK_PCT=5.0    # Max % of equity at risk across all open positions combined
ALLOCATOR_WINDOW_SEC=0.5      # Seconds to collect multi-symbol signals before ranking

# Kill switch: flatten everything + stop trading when session PnL drops below this %
KILL_SWITCH_LOSS_PCT=5.0

# Reconciler: on restart, sync open positions / orders / GTTs from Kite
RECONCILE_ON_START=true
RECONCILE_CANCEL_ORPHAN_ORDERS=true

# Trailing stop (software level; GTT floor stays at original SL)
TRAILING_STOP=false
TRAILING_STOP_PCT=0.3

# Exchange-native stops:
#   CNC  → Kite GTT (survives restarts; OCO when TAKE_PROFIT_PCT is set)
#   MIS  → SL-M order immediately after fill
USE_EXCHANGE_STOPS=false
FILL_CONFIRM_TIMEOUT_SEC=30.0

# Signal filters
USE_VWAP_FILTER=true
USE_VOLUME_FILTER=true
VOLUME_SMA_PERIOD=20
VOLUME_FILTER_MULT=1.2

# Stop entering new longs at/after this IST time
ENTRY_CUTOFF_TIME=15:00

KITE_PRODUCT=MIS
KITE_ORDER_VARIETY=regular

# Trade log (append-only JSONL)
TRADE_LOG_FILE=logs/trades.jsonl

LOG_LEVEL=INFO
DASHBOARD=true
